{
  "$schema": "workflow-v1",
  "id": "ntl",
  "name": "NTL Pipeline",
  "version": "1.0.0",
  "description": "Automatisierungs-Pipeline fuer NTL Kundenprojekt",
  "owner": "ntl-agent",
  "vm": "TBD",
  "source": {
    "type": "github-gist",
    "gistId": "00dcf34dcce25e7d7a5bb88c8f2ac101",
    "owner": "ExasyncOU",
    "currentSHA": "2b96907873cc7442067822b1ce276914cafa620c",
    "lastSynced": null,
    "files": ["edatagate_worker.py", "orchestrator.py", "config.json"]
  },
  "supabase": {
    "tables": ["workflow_runs"],
    "healthCheckSQL": "SELECT * FROM workflow_runs WHERE workflow = 'ntl' AND status = 'success' ORDER BY finished_at DESC LIMIT 1;"
  },
  "schedule": "*/15 * * * *",
  "stages": [
    {
      "id": "login",
      "name": "Portal Login",
      "type": "setup",
      "description": "e-datagate Portal Login fuer alle 7 Accounts parallel",
      "logging": true
    },
    {
      "id": "akzeptieren",
      "name": "Bedingungen akzeptieren",
      "type": "setup",
      "description": "Nutzungsbedingungen akzeptieren falls angezeigt",
      "logging": true
    },
    {
      "id": "navigate",
      "name": "Navigation zu Fahrplan",
      "type": "core",
      "description": "Zum Fahrplan-Export navigieren",
      "logging": true
    },
    {
      "id": "set_dates",
      "name": "Datumsbereich setzen",
      "type": "core",
      "description": "Aktuelle Woche setzen (Mo 00:00 bis So 23:59)",
      "logging": true
    },
    {
      "id": "download",
      "name": "XML Download",
      "type": "output",
      "description": "Fahrplan-XML herunterladen und speichern",
      "logging": true
    }
  ],
  "monitoring": {
    "dashboard": "A.I.D.A/workflows/index.html",
    "workflowRunsTable": "workflow_runs",
    "workflowId": "ntl",
    "alertOnFailure": true
  },
  "config": {
    "config_version": "1.0.0",
    "changelog": [
      "1.0.0 — Initiales Setup"
    ]
  }
}