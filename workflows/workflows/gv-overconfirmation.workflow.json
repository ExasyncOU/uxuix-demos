{
  "$schema": "workflow-v1",
  "id": "gv-overconfirmation",
  "name": "GV Overconfirmation (IDIS AROS)",
  "version": "1.4.2",
  "description": "Automatische Overconfirmation-Berechnung in IDIS AROS fuer GV Logistik. Bidirektionale Verarbeitung (Top+Bottom Bot) pro User, sequentiell ueber 3 IDIS-Accounts.",
  "owner": "gv-overconfirmation-agent",
