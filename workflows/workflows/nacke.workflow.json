{
  "$schema": "workflow-v1",
  "id": "nacke",
  "name": "NackeScript IDIS Auftragsbestätigung",
  "version": "7.0.1",
  "description": "Automatische Auftragsbestaetigung + Overconfirmation in IDIS fuer Nacke Logistik",
  "owner": "nacke-agent",
  "vm": "UXUIX (Nacke-VM)",
  "source": {
    "type": "github-gist",
    "gistId": "d8fe35c43d948ed0e898e4eb76049934",
    "owner": "ExasyncOU",
    "currentSHA": "07c03624662ee01c6d7b40407e4e29207d8f8e02",
    "lastSynced": "2026-03-16T13:30:00Z",
    "files": {
      "orchestrator.py": { "lines": 1061, "module": "nacke/orchestrator", "logging": true },
      "idis_selectors.py": { "lines": 146, "module": "nacke/idis-selectors", "logging": false },
      "idis_connect.py": { "lines": 162, "module": "nacke/idis-connect", "logging": true },
      "idis_login.py": { "lines": 170, "module": "nacke/idis-login", "logging": true },
      "idis_export.py": { "lines": 412, "module": "nacke/idis-export", "logging": true },
      "idis_amend.py": { "lines": 204, "module": "nacke/idis-amend", "logging": true },
      "idis_save_back.py": { "lines": 115, "module": "nacke/idis-save-back", "logging": true },
      "idis_browser.py": { "lines": 245, "module": "nacke/idis-browser-wrapper", "logging": true },
      "picklist_generator.py": { "lines": 1153, "module": "nacke/picklist-generator", "logging": true },
      "master_data.py": { "lines": 358, "module": "nacke/master-data", "logging": true },
      "overconfirmation.py": { "lines": 201, "module": "nacke/overconfirmation", "logging": true },
      "daily_report.py": { "lines": 252, "module": "nacke/daily-report", "logging": true },
      "printer.py": { "lines": 235, "module": "nacke/printer", "logging": true },
      "config.json": { "lines": 118, "module": "nacke/config" }
    }
  },
  "schedule": {
    "cron": "30 4 * * 1-4",
    "human": "Montag-Donnerstag um 04:30 Uhr",
    "timezone": "Europe/Berlin"
  },
  "guardrails": {
    "constraints": {
      "allowedDays": ["Monday", "Tuesday", "Wednesday", "Thursday"],
      "blockedDays": ["Friday", "Saturday", "Sunday"],
      "blockedReason": "Freitag-Sonntag: IDIS Wartungsfenster + Wochenabschluss",
      "allowedHours": { "start": "07:00", "end": "18:00" },
      "maxConcurrentRuns": 1,
      "timeoutMinutes": 120,
      "maxOrdersPerRun": 200,
      "dryRunDefault": true,
      "hardRules": [
        "NIEMALS Production remote via AFK Task starten (Incident 06.03.2026)",
        "NIEMALS annehmen dass Env-Variable Dry-Run ausloest ohne Aufrufpfad-Verifikation",
        "Fuer DRY-RUN IMMER dediziertes Dryrun-Script verwenden",
        "Bundle Size IMMER aus Col K (Einstellung RPR Kartonage) — NIEMALS Col J",
        "Overconfirmation Faktor IMMER 1 (PCS=1, PPP=1) — NIEMALS factor_ppp=3",
        "Frischer Browser-Context pro Land (PARALLEL via CDP) — kein State-Bleed zwischen Laendern",
        "NIEMALS wait_for_load_state('networkidle') bei CDP — haengt den Browser. NUR wait_for_timeout()",
        "Save = mainForm:_idJsp159, Back = mainForm:_idJsp155 — NIEMALS vertauschen!",
        "Overconfirmation per JS im Amend-Form: ceil(ordered/bundle)*bundle PRO Destination",
        "Tabelle direkt iterieren — NIEMALS per Order-ID aus CSV matchen",
        "Nach Gist-Update IMMER SHA in run_nacke_v2.ps1 aktualisieren — sonst zieht Scheduler alte Version",
        "Keine except:pass — JEDE Exception muss geloggt werden (logger.warning minimum)"
      ],
      "frozenLogic": {
        "version": "7.0.1",
        "frozenAt": "2026-03-16",
        "pipelineGistSHA": "pending-update",
        "deployGistSHA": "14fa2e61c5ec1ce54230623eb5b935e4e8fe759a",
        "bundleSource": "Col K (Einstellung RPR Kartonage), OL: OL Kartonage Sheet",
        "overconfirmationFactor": { "PCS": 1, "PPP": 1 },
        "browserStrategy": "fresh-context-per-country-parallel",
        "browserModules": ["idis_selectors", "idis_connect", "idis_login", "idis_export", "idis_amend", "idis_save_back"],
        "smtpUser": "bot@uxuix.de",
        "smtpVia": "Edge Function nacke-report (Vault Secrets)"
      }
    },
    "variables": [
      { "name": "NACKE_DRYRUN", "type": "boolean", "default": true, "description": "Dry-Run Modus (keine echten Bestaetigungen)", "locked": true, "lockReason": "Sicherheitskritisch - nur manuell aenderbar" },
      { "name": "NACKE_MAX_ORDERS", "type": "number", "default": 50, "min": 1, "max": 200, "description": "Max Auftraege pro Lauf" },
      { "name": "IDIS_URL", "type": "string", "default": "https://idis.nacke.de", "locked": true, "description": "IDIS Server URL" },
      { "name": "IDIS_USER", "type": "string", "default": "from_vault", "locked": true, "description": "IDIS Login (aus credential_vault)" },
      { "name": "REPORT_RECIPIENTS", "type": "string[]", "default": ["bodo.buschick@uxuix.de"], "description": "Email-Empfaenger fuer Reports" },
      { "name": "SMTP_USER", "type": "string", "default": "bot@uxuix.de", "locked": true, "description": "SMTP Absender (Geo: Deutschland/Kunden-VMs)" }
    ]
  },
  "lanes": [
    { "id": "orchestrator", "label": "Orchestrator", "icon": "🎯", "color": "#4A90D9", "description": "Steuert den Ablauf, Config, Error Handling" },
    { "id": "data", "label": "Daten / Supabase", "icon": "📊", "color": "#27AE60", "description": "Datenbank-Operationen, Stammdaten, Auftraege" },
    { "id": "idis", "label": "IDIS Browser", "icon": "🌐", "color": "#E67E22", "description": "Playwright Browser-Automation in IDIS" },
    { "id": "reporting", "label": "Reporting", "icon": "📧", "color": "#8E44AD", "description": "Email-Reports, Metriken, Logging" }
  ],
  "steps": [
    {
      "id": "config-load",
      "lane": "orchestrator",
      "module": "nacke/config",
      "label": "Config laden",
      "description": "Config aus Supabase laden, validieren, config_version pruefen",
      "next": ["master-data"],
      "inputs": ["supabase:agent_configs"],
      "outputs": ["config{}"]
    },
    {
      "id": "master-data",
      "lane": "data",
      "module": "nacke/master-data",
      "label": "Stammdaten laden",
      "description": "Kundenstammdaten und Zuordnungstabellen aus Supabase",
      "next": ["fetch-orders"],
      "inputs": ["config.flow_name"],
      "outputs": ["masterData{}"]
    },
    {
      "id": "fetch-orders",
      "lane": "data",
      "module": "nacke/orchestrator",
      "label": "Auftraege abrufen",
      "description": "Offene Auftraege aus nacke_orders Tabelle laden",
      "next": ["idis-login"],
      "inputs": ["config", "masterData"],
      "outputs": ["orders[]"]
    },
    {
      "id": "idis-login",
      "lane": "idis",
      "module": "nacke/idis-browser",
      "label": "IDIS Login",
      "description": "Playwright startet Browser, navigiert zu IDIS, Login mit Credentials aus Vault",
      "next": ["navigate-page"],
      "inputs": ["config.idis_url", "vault:idis_credentials"],
      "outputs": ["browser_session"]
    },
    {
      "id": "navigate-page",
      "lane": "idis",
      "module": "nacke/idis-browser",
      "label": "Seite navigieren",
      "description": "Zur Auftragsbestaetigung-Seite navigieren, Selektoren pruefen",
      "next": ["confirm-orders"],
      "inputs": ["browser_session"],
      "outputs": ["page_ready"]
    },
    {
      "id": "confirm-orders",
      "lane": "idis",
      "module": "nacke/idis-browser",
      "label": "Auftraege bestaetigen",
      "description": "Schleife: Jeden Auftrag im IDIS bestaetigen (oder Dry-Run loggen)",
      "next": ["save-results"],
      "inputs": ["orders[]", "page_ready", "NACKE_DRYRUN"],
      "outputs": ["results[]"]
    },
    {
      "id": "save-results",
      "lane": "data",
      "module": "nacke/orchestrator",
      "label": "Ergebnis speichern",
      "description": "Bestaetigungsergebnisse zurueck nach Supabase schreiben",
      "next": ["generate-picklists"],
      "inputs": ["results[]"],
      "outputs": ["saved_count"]
    },
    {
      "id": "generate-picklists",
      "lane": "reporting",
      "module": "nacke/picklist-generator",
      "label": "Picklisten generieren",
      "description": "Excel + PDF Raussuchlisten aus Post-Export-Daten generieren. Sortiert nach Class, mit Seitenumbruch vor Summenblock.",
      "next": ["generate-report"],
      "inputs": ["results[]", "config", "masterData"],
      "outputs": ["picklists[]"]
    },
    {
      "id": "generate-report",
      "lane": "reporting",
      "module": "nacke/daily-report",
      "label": "Report erstellen",
      "description": "Tagesreport als HTML generieren mit Zusammenfassung",
      "next": ["send-email"],
      "inputs": ["results[]", "config"],
      "outputs": ["report_html"]
    },
    {
      "id": "send-email",
      "lane": "reporting",
      "module": "nacke/daily-report",
      "label": "Email senden",
      "description": "Report per SMTP an konfigurierte Empfaenger senden",
      "next": ["log-metrics"],
      "inputs": ["report_html", "REPORT_RECIPIENTS", "SMTP_USER"],
      "outputs": ["email_sent"]
    },
    {
      "id": "log-metrics",
      "lane": "orchestrator",
      "module": "core/metrics-collector",
      "label": "Metriken loggen",
      "description": "Laufzeit, Anzahl Auftraege, Fehler nach agent_metrics schreiben",
      "next": [],
      "inputs": ["results[]", "timing"],
      "outputs": ["metrics_logged"]
    }
  ],
  "errorHandling": {
    "module": "core/error-handler",
    "strategy": "log-and-report",
    "escalation": "email-to-bodo"
  }
}
