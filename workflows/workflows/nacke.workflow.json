  "schedule": {
    "cron": "10 4 * * 1-4",
    "human": "Montag-Donnerstag um 04:10 Uhr",
    "timezone": "Europe/Berlin"
  },
  "guardrails": {
    "constraints": {
      "allowedDays": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday"
      ],
      "blockedDays": [
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "blockedReason": "Freitag-Sonntag: IDIS Wartungsfenster + Wochenabschluss",
      "allowedHours": {
        "start": "07:00",
        "end": "18:00"
      },
      "maxConcurrentRuns": 1,
      "timeoutMinutes": 120,
      "maxOrdersPerRun": 200,
      "dryRunDefault": true,
      "hardRules": [
        "NIEMALS Production remote via AFK Task starten (Incident 06.03.2026)",
        "NIEMALS annehmen dass Env-Variable Dry-Run ausloest ohne Aufrufpfad-Verifikation",
        "Fuer DRY-RUN IMMER dediziertes Dryrun-Script verwenden",
        "Bundle Size IMMER aus Col K (Einstellung RPR Kartonage) — NIEMALS Col J",
        "Overconfirmation Faktor IMMER 1 (PCS=1, PPP=1) — NIEMALS factor_ppp=3",
        "Frischer Browser-Context pro Land (PARALLEL via CDP) — kein State-Bleed zwischen Laendern",
        "NIEMALS wait_for_load_state('networkidle') bei CDP — haengt den Browser. NUR wait_for_timeout()",
        "Save = mainForm:_idJsp159, Back = mainForm:_idJsp155 — NIEMALS vertauschen!",
        "Overconfirmation per JS im Amend-Form: ceil(ordered/bundle)*bundle PRO Destination",
        "Tabelle direkt iterieren — NIEMALS per Order-ID aus CSV matchen",
        "Nach Gist-Update IMMER SHA in run_nacke_v2.ps1 aktualisieren — sonst zieht Scheduler alte Version",
        "Druck NUR via LPR (lpr.exe) — NIEMALS Out-Printer fuer PDFs, NIEMALS SumatraPDF (haengt headless)"
      ],
      "frozenLogic": {
        "version": "7.6.0",
        "frozenAt": "2026-03-24",
        "pipelineGistSHA": "3d13d8216a7ddc6f374a8054fdff6f85b327931e",
        "deployGistSHA": "0b026c34902224d608b645ea463658d3715be167",
        "bundleSource": "Col K (Einstellung RPR Kartonage), OL: OL Kartonage Sheet",
        "overconfirmationFactor": {
          "PCS": 1,
          "PPP": 1
        },
        "browserStrategy": "fresh-context-per-country-parallel",
        "browserModules": [
          "idis_selectors",
          "idis_connect",
          "idis_login",
          "idis_export",
          "idis_amend",
          "idis_save_back"
        ],
        "smtpUser": "bot@uxuix.de",
        "smtpVia": "Edge Function nacke-report (Vault Secrets)",
        "printMethod": "LPR via lpr.exe -S 192.168.5.25 -P lp -o l (headless, kein GUI)"
      }
    },
    "variables": [
      {
        "name": "NACKE_DRYRUN",
        "type": "boolean",
        "default": true,
        "description": "Dry-Run Modus (keine echten Bestaetigungen)",
        "locked": true,
        "lockReason": "Sicherheitskritisch - nur manuell aenderbar"
      },
      {
        "name": "NACKE_MAX_ORDERS",
        "type": "number",
        "default": 50,
        "min": 1,
        "max": 200,
        "description": "Max Auftraege pro Lauf"
      },
      {
        "name": "IDIS_URL",
        "type": "string",
        "default": "https://idis.nacke.de",
        "locked": true,
        "description": "IDIS Server URL"
      },
      {
        "name": "IDIS_USER",
        "type": "string",
        "default": "from_vault",
        "locked": true,
        "description": "IDIS Login (aus credential_vault)"
      },
      {
        "name": "REPORT_RECIPIENTS",
        "type": "string[]",
        "default": [
          "bodo.buschick@uxuix.de"
        ],
        "description": "Email-Empfaenger fuer Reports"
      },
      {
        "name": "SMTP_USER",
        "type": "string",
        "default": "bot@uxuix.de",
        "locked": true,
        "description": "SMTP Absender (Geo: Deutschland/Kunden-VMs)"
      }
    ]
  },
  "lanes": [
    {
      "id": "orchestrator",
      "label": "Orchestrator",
      "icon": "🎯",
      "color": "#4A90D9",
      "description": "Steuert den Ablauf, Config, Error Handling"
    },
    {
      "id": "data",
      "label": "Daten / Supabase",
      "icon": "📊",
      "color": "#27AE60",
      "description": "Datenbank-Operationen, Stammdaten, Auftraege"
    },
    {
      "id": "idis",
      "label": "IDIS Browser",
      "icon": "🌐",
      "color": "#E67E22",
      "description": "Playwright Browser-Automation in IDIS"
    },
    {
      "id": "reporting",
      "label": "Reporting",
      "icon": "📧",
      "color": "#8E44AD",
      "description": "Email-Reports, Metriken, Logging"
    }
  ],
  "steps": [
    {
      "id": "config-load",
      "lane": "orchestrator",
      "module": "nacke/config",
      "label": "Config laden",
      "description": "Config aus Supabase laden, validieren, config_version pruefen",
      "next": [
        "send-start-email"
      ],
      "inputs": [
        "supabase:agent_configs"
      ],
      "outputs": [
        "config{}"
      ]
    },
    {
      "id": "send-start-email",
      "lane": "reporting",
      "module": "nacke/nacke-email",
      "label": "Start-Email senden",
      "description": "Benachrichtigung dass Pipeline gestartet wurde (Modus, Maschine, Zeitstempel)",
      "next": [
        "master-data"
      ],
      "inputs": [
        "config",
        "mode"
      ],
      "outputs": [
        "start_email_sent"
      ]
    },
    {
      "id": "master-data",
      "lane": "data",
      "module": "nacke/master-data",
      "label": "Stammdaten laden",
      "description": "Kundenstammdaten und Zuordnungstabellen aus Supabase",
      "next": [
        "fetch-orders"
      ],
      "inputs": [
        "config.flow_name"
      ],
      "outputs": [
        "masterData{}"
      ]
    },
    {
      "id": "fetch-orders",
      "lane": "data",
      "module": "nacke/orchestrator",
      "label": "Auftraege abrufen",
      "description": "Offene Auftraege aus nacke_orders Tabelle laden",
      "next": [
        "idis-connect"
      ],
      "inputs": [
        "config",
        "masterData"
      ],
      "outputs": [
        "orders[]"
      ]
    },
    {
      "id": "idis-connect",
      "lane": "idis",
      "module": "nacke/idis-connect",
      "label": "CDP verbinden",
      "description": "Chrome Debug Protocol Verbindung zum IDIS-Browser herstellen (Port 9222)",
      "next": [
        "idis-login"
      ],
      "inputs": [
        "config.cdp_port"
      ],
      "outputs": [
        "cdp_session"
      ]
    },
    {
      "id": "idis-login",
      "lane": "idis",
      "module": "nacke/idis-login",
      "label": "IDIS Login",
      "description": "Login bei IDIS mit Credentials aus Vault, Session-Cookie sichern",
      "next": [
        "idis-selectors"
      ],
      "inputs": [
        "cdp_session",
        "vault:idis_credentials"
      ],
      "outputs": [
        "browser_session"
      ]
    },
    {
      "id": "idis-selectors",
      "lane": "idis",
      "module": "nacke/idis-selectors",
      "label": "Selektoren laden",
      "description": "JSF-Selektoren fuer IDIS-Formulare laden und validieren",
      "next": [
        "idis-export"
      ],
      "inputs": [
        "browser_session"
      ],
      "outputs": [
        "selectors{}"
      ]
    },
    {
      "id": "idis-export",
      "lane": "idis",
      "module": "nacke/idis-export",
      "label": "Auftraege exportieren",
      "description": "Offene Auftraege aus IDIS-Tabelle exportieren und parsen",
      "next": [
        "idis-amend"
      ],
      "inputs": [
        "browser_session",
        "selectors",
        "orders[]"
      ],
      "outputs": [
        "export_data[]"
      ]
    },
    {
      "id": "idis-amend",
      "lane": "idis",
      "module": "nacke/idis-amend",
      "label": "Amendments durchfuehren",
      "description": "Bestellmengen im IDIS-Formular aendern (Amend), Overconfirmation anwenden",
      "next": [
        "idis-save-back"
      ],
      "inputs": [
        "export_data[]",
        "selectors",
        "NACKE_DRYRUN"
      ],
      "outputs": [
        "amended[]"
      ]
    },
    {
      "id": "idis-save-back",
      "lane": "idis",
      "module": "nacke/idis-save-back",
      "label": "Save + Back",
      "description": "Aenderungen speichern (Save _idJsp159) und zurueck navigieren (_idJsp155)",
      "next": [
        "overconfirmation"
      ],
      "inputs": [
        "amended[]",
        "selectors"
      ],
      "outputs": [
        "saved[]"
      ]
    },
    {
      "id": "overconfirmation",
      "lane": "data",
      "module": "nacke/overconfirmation",
      "label": "Overconfirmation",
      "description": "Mengen auf Bundle-Size aufrunden: ceil(ordered/bundle)*bundle. Faktor IMMER 1.",
      "next": [
        "idis-packaging"
      ],
      "inputs": [
        "saved[]",
        "masterData"
      ],
      "outputs": [
        "confirmed[]"
      ]
    },
    {
      "id": "idis-packaging",
      "lane": "data",
      "module": "nacke/idis-packaging",
      "label": "Kartonage berechnen",
      "description": "Verpackungseinheiten (PPP/PCS) aus Col K berechnen, Bundle-Zuordnung",
      "next": [
        "save-results"
      ],
      "inputs": [
        "confirmed[]",
        "masterData"
      ],
      "outputs": [
        "packaged[]"
      ]
    },
    {
      "id": "save-results",
      "lane": "data",
      "module": "nacke/orchestrator",
      "label": "Ergebnis speichern",
      "description": "Bestaetigungsergebnisse zurueck nach Supabase schreiben",
      "next": [
        "generate-picklists"
      ],
      "inputs": [
        "packaged[]"
      ],
      "outputs": [
        "saved_count"
      ]
    },
    {
      "id": "generate-picklists",
      "lane": "reporting",
      "module": "nacke/picklist-generator",
      "label": "Picklisten generieren (Excel)",
      "description": "Excel-Raussuchlisten generieren. Sortiert nach Class, PCS/PPP-Templates, Summenblock.",
      "next": [
        "generate-pdfs"
      ],
      "inputs": [
        "packaged[]",
        "config",
        "masterData"
      ],
      "outputs": [
        "picklists[]"
      ]
    },
    {
      "id": "generate-pdfs",
      "lane": "reporting",
      "module": "nacke/picklist-pdf",
      "label": "PDF generieren",
      "description": "Excel-Picklisten als A4-Landscape-PDF rendern. Summenblock-Seitenumbruch, Footer mit Seitenzahlen.",
      "next": [
        "print-picklists"
      ],
      "inputs": [
        "picklists[]"
      ],
      "outputs": [
        "pdfs[]"
      ]
    },
    {
      "id": "print-picklists",
      "lane": "reporting",
      "module": "nacke/printer",
      "label": "Picklisten drucken",
      "description": "Generierte Picklists auf dem Netzwerkdrucker der Nacke-VM ausgeben",
      "next": [
        "generate-todo-list"
      ],
      "inputs": [
        "picklists[]",
        "config.printer"
      ],
      "outputs": [
        "printed_count"
      ]
    },
    {
      "id": "generate-todo-list",
      "lane": "reporting",
      "module": "nacke/generate-todo-list",
      "label": "Schritt 9: ToDo-Liste",
      "next": [
        "generate-report"
      ]
    },
    {
      "id": "generate-report",
      "lane": "reporting",
      "module": "nacke/daily-report",
      "label": "Report erstellen",
      "description": "Tagesreport als HTML generieren mit Zusammenfassung aller Ergebnisse",
      "next": [
        "send-end-email"
      ],
      "inputs": [
        "packaged[]",
        "config"
      ],
      "outputs": [
        "report_html"
      ]
    },
    {
      "id": "send-end-email",
      "lane": "reporting",
      "module": "nacke/nacke-email",
      "label": "End-Email senden",
      "description": "Report-Email mit Ergebnis (Amendments, Picklisten, Fehler) per SMTP senden",
      "next": [
        "log-metrics"
      ],
      "inputs": [
        "result{}",
        "REPORT_RECIPIENTS"
      ],
      "outputs": [
        "end_email_sent"
      ]
    },
    {
      "id": "log-metrics",
      "lane": "orchestrator",
      "module": "core/metrics-collector",
      "label": "Metriken loggen",
      "description": "Laufzeit, Anzahl Auftraege, Fehler nach agent_metrics schreiben",
      "next": [],
      "inputs": [
        "packaged[]",
        "timing"
      ],
      "outputs": [
        "metrics_logged"
      ]
    }
  ],
  "errorHandling": {
    "module": "core/error-handler",
    "strategy": "log-and-report",
    "escalation": "email-to-bodo"
  },
  "monitoring": {
    "healthCheck": "SELECT started_at, status, stats->'steps'->'todo_list' AS todo, stats->'steps'->'print' AS print FROM workflow_runs WHERE workflow = 'nacke' ORDER BY started_at DESC LIMIT 5",
    "metrics": {
      "avg_orders_per_run": 131,
      "avg_picklists_generated": 131,
      "pipeline_version": "v4.1",
      "last_known_issue": "2026-04-09 printer buffer - fixed with 60s batch pause every 10 lists"
    },
    "lastRun": "2026-04-09T04:34:16Z"
  }
}
