  "schedule": {
    "cron": "0 4 * * 1,2,3",
    "human": "Mo, Di, Mi um 04:00 CET (nach v2 Deploy)",
    "timezone": "Europe/Berlin",
    "managedBy": "uxuix_schedules"
  },
  "guardrails": {
    "constraints": {
      "allowedDays": ["Monday", "Tuesday", "Wednesday"],
      "allowedHours": { "start": "04:00", "end": "06:00" },
      "maxConcurrentRuns": 1,
      "timeoutMinutes": 30,
      "hardRules": [
        "Sequentielle User-Verarbeitung (NICHT parallel)",
        "Depot-Filter (destinationTypeFilter=D) MUSS gesetzt sein",
        "PYTHONIOENCODING=utf-8 in run_multi.ps1 UND im Python-Code",
        "Save=_idJsp159, Back=_idJsp155 - NIEMALS verwechseln",
        "VM config.json ist Source of Truth"
      ]
    },
    "frozenLogic": {
      "version": "2.0.0",
      "frozenAt": "2026-03-23",
      "overconfirmationFormula": "ceil(ordered / bundle) * bundle",
      "earlyStopThreshold": 3,
      "saveSelector": "mainForm:_idJsp159",
      "backSelector": "mainForm:_idJsp155"
    },
    "variables": [
      { "name": "IDIS_USER", "type": "string", "values": ["IDIS155", "IDIS735", "IDIS736"], "locked": true },
      { "name": "CDP_PORT", "type": "number", "values": [9222, 9223, 9224], "locked": true }
    ]
  },
  "lanes": [
    { "id": "config", "label": "Config", "icon": "settings", "color": "#95A5A6" },
    { "id": "browser", "label": "Browser", "icon": "globe", "color": "#3498DB" },
    { "id": "idis", "label": "IDIS", "icon": "log-in", "color": "#E67E22" },
    { "id": "orders", "label": "Orders", "icon": "list", "color": "#2ECC71" },
    { "id": "processing", "label": "Processing", "icon": "zap", "color": "#F39C12" },
    { "id": "reporting", "label": "Reporting", "icon": "bar-chart", "color": "#E74C3C" },
    { "id": "pipeline", "label": "Pipeline", "icon": "git-merge", "color": "#8E44AD" }
  ],
  "steps": [
    { "id": "config-load", "lane": "config", "module": "gv-overconfirmation-v2/config", "label": "Config laden", "description": "CLI Args, .env, config.json, Report-Dict.", "next": ["browser-start"], "inputs": ["ENV_FILE"], "outputs": ["CFG", "REPORT"], "script": "config.py" },
    { "id": "browser-start", "lane": "browser", "module": "gv-overconfirmation-v2/browser", "label": "Chrome CDP starten", "description": "Chrome detached starten, CDP verbinden.", "next": ["idis-login"], "inputs": ["CDP_PORT"], "outputs": ["browser", "pw"], "script": "browser.py" },
    { "id": "idis-login", "lane": "idis", "module": "gv-overconfirmation-v2/idis", "label": "IDIS Login", "description": "Login mit j_username/j_password. Dual-Context.", "next": ["aros-navigate"], "inputs": ["IDIS_USER", "IDIS_PASS"], "outputs": ["login_ok"], "script": "idis.py" },
    { "id": "aros-navigate", "lane": "idis", "module": "gv-overconfirmation-v2/idis", "label": "AROS Navigation", "description": "Process AROS Orders oeffnen, Show Result.", "next": ["read-orders"], "inputs": ["page"], "outputs": ["aros_page"], "script": "idis.py" },
    { "id": "read-orders", "lane": "orders", "module": "gv-overconfirmation-v2/orders", "label": "Orders lesen + klassifizieren", "description": "Tabelle parsen, Orders in valid/skipped aufteilen.", "next": ["process-orders"], "inputs": ["page"], "outputs": ["valid_orders"], "script": "orders.py" },
    { "id": "process-orders", "lane": "processing", "module": "gv-overconfirmation-v2/processor", "label": "Bidirektional verarbeiten", "description": "TOP+BOT parallel. Amend, Overconfirmation, Save/Back.", "next": ["generate-report"], "inputs": ["valid_orders"], "outputs": ["stats"], "script": "processor.py" },
    { "id": "generate-report", "lane": "reporting", "module": "gv-overconfirmation-v2/report", "label": "Report + Email", "description": "HTML-Report generieren, via Edge Function senden.", "next": ["pipeline-finish"], "inputs": ["REPORT"], "outputs": ["html", "email_sent"], "script": "report.py" },
    { "id": "pipeline-finish", "lane": "pipeline", "module": "gv-overconfirmation-v2/main", "label": "Pipeline abschliessen", "description": "Report-Dateien speichern, Contexts schliessen.", "next": [], "inputs": ["all_results"], "outputs": ["done"], "script": "main.py" }
  ],
  "supabaseTables": [
    { "name": "gvsped_reports", "purpose": "Reports", "rw": "rw" },
    { "name": "workflow_runs", "purpose": "Monitoring", "rw": "write" }
  ],
  "errorHandling": {
    "module": "core/error-handler",
    "strategy": "log-and-continue"
  }
