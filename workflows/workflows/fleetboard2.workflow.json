{
  "$schema": "workflow-v1",
  "id": "fleetboard2",
  "name": "Fleetboard 2.0",
  "version": "2.2.0",
  "description": "GPS-Tracking + Ankunftserkennung fuer GV Logistik — Matcher liest aus DB, Auto-Deploy via Gist",
  "frozenAt": "2026-03-18T09:15:00Z",
  "owner": "fleetboard-agent",
  "vm": "UXUIX (157.180.78.163)",
  "vmPath": "C:\\FleetboardScript\\",
  "source": {
    "type": "gist",
    "gistId": "771c490a2fde04847cacdb439a227966",
    "gistUrl": "https://gist.github.com/ExasyncOU/771c490a2fde04847cacdb439a227966",
    "repoBackup": "fleetboard2/"
  },
  "schedule": {
    "cron": "5,20,35,50 * * * 1-6",
    "human": "Alle 15 Min (Mo-Sa), GPS jede Minute separat",
    "timezone": "Europe/Berlin"
  },
  "guardrails": {
    "constraints": {
      "maxConcurrentRuns": 1,
      "timeoutMinutes": 4,
      "hardRules": [
        "Max 4 Min Laufzeit (15-Min-Cron-Takt)",
        "IMAP: gvlog@uxuix.de (1x taeglich 10:00)",
        "GVLOGMG: 3-fach Validierung (nach Zustellstopp, max 4h, nach erstem Soll)"
      ]
    },
    "variables": []
  },
  "lanes": [
    { "id": "geodata", "label": "Geodaten", "icon": "map-pin", "color": "#27AE60", "description": "Areas + Mappings aus Supabase, lokaler Cache" },
    { "id": "pipeline", "label": "Pipeline", "icon": "zap", "color": "#4A90D9", "description": "DB(AUSSTEHEND) -> GPS -> Match -> DB(MATCH)" },
    { "id": "data", "label": "Daten", "icon": "database", "color": "#8E44AD", "description": "Supabase Reads/Writes" },
    { "id": "monitor", "label": "Monitor", "icon": "activity", "color": "#E74C3C", "description": "Unknown Refs, Metriken, Alerts" }
  ],
  "steps": [
    {
      "id": "sync-geodata", "lane": "geodata", "module": "fleetboard2/sync-geodata", "label": "Geodaten Sync",
      "frozen": true, "frozenAt": "2026-03-17", "frozenReason": "53 Areas, Cache stabil",
      "description": "Areas + Mappings aus Supabase laden, lokal als JSON cachen.",
      "next": ["check-refs"], "inputs": ["supabase:fleetboard_areas"], "outputs": ["cache/geodata.json"], "script": "sync-geodata.mjs"
    },
    {
      "id": "check-refs", "lane": "monitor", "module": "fleetboard2/check-refs", "label": "Zustellreferenzen pruefen",
      "description": "CSV-Refs gegen Geodaten-Cache pruefen. Unbekannte -> fleetboard_unknown_refs.",
      "next": [], "inputs": ["cache/geodata.json", "csv_file"], "outputs": ["fleetboard_unknown_refs"], "script": "check-refs.mjs"
    },
    {
      "id": "fetch-positions", "lane": "pipeline", "module": "fleetboard2/fetch-positions", "label": "GPS Fetch",
      "frozen": true, "frozenAt": "2026-03-17", "frozenReason": "6700+ Runs, 80 Fahrzeuge/min",
      "description": "Aktuelle Position aller Fahrzeuge via SOAP API abrufen.",
      "next": [], "inputs": ["fleetboard-soap-api"], "outputs": ["supabase:fleetboard_positions"], "script": "fetch-positions.mjs"
    },
    {
      "id": "fetch-tours", "lane": "pipeline", "module": "fleetboard2/fetch-tours", "label": "IMAP CSV Fetch",
      "frozen": true, "frozenAt": "2026-03-18", "frozenReason": "v2.2 — Auto DB-Import nach Download",
      "description": "Tourenabfrage-CSV per IMAP holen, automatisch in DB importieren.",
      "next": ["match-tours"], "inputs": ["imap:gvlog@uxuix.de"], "outputs": ["cache/Tourenabfrage_*.csv", "supabase:fleetboard_arrivals(AUSSTEHEND)"], "script": "fetch-tours.mjs"
    },
    {
      "id": "match-tours", "lane": "pipeline", "module": "fleetboard2/match-tours", "label": "Tour-Matcher",
      "frozen": true, "frozenAt": "2026-03-18", "frozenReason": "v2.2 — Liest AUSSTEHEND aus DB, UNIQUE Constraint, Auto-Deploy via Gist",
      "description": "Liest AUSSTEHEND-Eintraege aus fleetboard_arrivals, matcht gegen GPS. Begegnungsverkehr-Fallback. Auto-Download vom Gist.",
      "next": [], "inputs": ["supabase:fleetboard_arrivals(AUSSTEHEND)", "cache/geodata.json", "supabase:fleetboard_positions"], "outputs": ["supabase:fleetboard_arrivals", "supabase:workflow_runs"], "script": "match-tours.mjs"
    },
    {
      "id": "shared-lib", "lane": "data", "module": "fleetboard2/lib", "label": "Shared Library",
      "frozen": true, "frozenAt": "2026-03-17", "frozenReason": "Supabase-Client + .env + Cache. Stabil.",
      "description": "Gemeinsame Bibliothek: Supabase-Client, .env-Loader, Cache read/write.",
      "next": [], "inputs": [".env"], "outputs": ["sb (Supabase Client)"], "script": "lib.mjs"
    }
  ],
  "supabaseTables": [
    { "name": "fleetboard_areas", "purpose": "53 Gebiete mit Bounding-Boxes", "rw": "read" },
    { "name": "fleetboard_mappings", "purpose": "Zustellreferenz -> Gebietsname", "rw": "rw" },
    { "name": "fleetboard_unknown_refs", "purpose": "Unbekannte Refs fuer Monitor", "rw": "write" },
    { "name": "fleetboard_arrivals", "purpose": "Tour-Stops mit Match-Ergebnissen (UNIQUE: tour_nr+zustellreferenz+soll_ankunft)", "rw": "rw" },
    { "name": "fleetboard_positions", "purpose": "GPS-Positionen pro Minute pro Fahrzeug", "rw": "write" },
    { "name": "fleetboard_vehicles", "purpose": "VehicleID -> Kennzeichen Cache", "rw": "rw" },
    { "name": "workflow_runs", "purpose": "Monitoring pro Lauf", "rw": "write" }
  ],
  "errorHandling": {
    "strategy": "log-and-continue",
    "escalation": "workflow_incidents + email-to-bodo"
  }
}