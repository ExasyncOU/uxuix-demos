    },
    {
      "id": "processing",
      "label": "Verarbeitung",
      "icon": "🔍",
      "color": "#E67E22",
      "description": "OCR, Artikelzuordnung, Validierung"
    },
    {
      "id": "data",
      "label": "Daten / Supabase",
      "icon": "📊",
      "color": "#8E44AD",
      "description": "Bestellungen speichern, Status, Metriken"
    },
    {
      "id": "output",
      "label": "Ausgabe",
      "icon": "📧",
      "color": "#E74C3C",
      "description": "XLSX-Export, Email, OneDrive Upload"
    }
  ],
  "steps": [
    {
      "id": "scheduler-start",
      "lane": "scheduler",
      "module": "welzhofer/scheduler",
      "label": "Scheduler starten",
      "description": "start-welzhofer.bat startet scheduler.py im Dauerbetrieb",
      "next": [
        "email-poll",
        "webhook-listen"
      ],
      "inputs": [
        "scheduled-task:WelzhoferStart"
      ],
      "outputs": [
        "scheduler_running"
      ]
    },
    {
      "id": "email-poll",
      "lane": "intake",
      "module": "welzhofer/scheduler",
      "label": "Email-Polling",
      "description": "Alle 5 Min neue Emails in automation@welzhofer.eu pruefen (IMAP)",
      "next": [
        "extract-attachment"
      ],
      "inputs": [
        "scheduler_running",
        "EMAIL_ACCOUNT"
      ],
      "outputs": [
        "new_emails[]"
      ]
    },
    {
      "id": "webhook-listen",
      "lane": "intake",
      "module": "welzhofer/webhook",
      "label": "Webhook empfangen",
      "description": "POST an receive-webhook-order — Bestellungen von externen Partnern",
      "next": [
        "save-order"
      ],
      "inputs": [
        "webhook_payload"
      ],
      "outputs": [
        "order_id"
      ],
      "edgeFunction": "receive-webhook-order"
    },
    {
      "id": "extract-attachment",
      "lane": "intake",
      "module": "welzhofer/scheduler",
      "label": "Attachment extrahieren",
      "description": "PDF/JPG Anhaenge aus Email extrahieren",
      "next": [
        "convert-image"
      ],
      "inputs": [
        "new_emails[]"
      ],
      "outputs": [
        "attachments[]"
      ]
    },
    {
      "id": "convert-image",
      "lane": "processing",
      "module": "welzhofer/convertapi",
      "label": "Bild konvertieren",
      "description": "PDF→PNG, JPG→PNG via ConvertAPI",
      "next": [
        "ocr-extract"
      ],
      "inputs": [
        "attachments[]",
        "CONVERTAPI_KEY"
      ],
      "outputs": [
        "images[]"
      ]
    },
    {
      "id": "ocr-extract",
      "lane": "processing",
      "module": "welzhofer/ocr",
      "label": "OCR Extraktion",
      "description": "GPT-5.2 Vision: Bestelldaten aus Bild extrahieren",
      "next": [
        "article-match"
      ],
      "inputs": [
        "images[]",
        "OPENAI_API_KEY"
      ],
      "outputs": [
        "raw_order_data{}"
      ]
    },
    {
      "id": "article-match",
      "lane": "processing",
      "module": "welzhofer/smart-match",
      "label": "Artikel zuordnen",
      "description": "Smart Matching: Text+Nummern-Similarity, Learning Store, Kategorie-Zuordnung",
      "next": [
        "save-order"
      ],
      "inputs": [
        "raw_order_data{}",
        "master_data",
        "learned_corrections"
      ],
      "outputs": [
        "validated_order{}"
      ]
    },
    {
      "id": "save-order",
      "lane": "data",
      "module": "welzhofer/supabase",
      "label": "Bestellung speichern",
      "description": "INSERT in welzhofer_orders (status=pending), workflow_runs Eintrag",
      "next": [
        "categorize"
      ],
      "inputs": [
        "validated_order{}",
        "order_id"
      ],
      "outputs": [
        "order_saved"
      ]
    },
    {
      "id": "categorize",
      "lane": "processing",
      "module": "welzhofer/categorizer",
      "label": "Kategorisieren",
      "description": "Futterhaus, Fressnapf, Andere, Nachbestellung, Handnotizen, Art.-Problem, Fremd-Art., Ohne Auftragsnr.",
      "next": [
        "xlsx-export"
      ],
      "inputs": [
        "validated_order{}"
      ],
      "outputs": [
        "category"
      ]
    },
    {
      "id": "xlsx-export",
      "lane": "output",
      "module": "welzhofer/export",
      "label": "XLSX Export",
      "description": "Bestellung als XLSX exportieren und auf OneDrive hochladen",
      "next": [
        "send-email",
        "update-status"
      ],
      "inputs": [
        "validated_order{}",
        "category"
      ],
      "outputs": [
        "xlsx_file"
      ]
    },
    {
      "id": "send-email",
      "lane": "output",
      "module": "welzhofer/email",
      "label": "Email versenden",
      "description": "Verarbeitete Bestellung per Email an Welzhofer senden",
      "next": [
        "log-metrics"
      ],
      "inputs": [
        "xlsx_file",
        "REPORT_RECIPIENTS"
      ],
      "outputs": [
        "email_sent"
      ]
    },
    {
      "id": "update-status",
      "lane": "data",
      "module": "welzhofer/supabase",
      "label": "Status aktualisieren",
      "description": "welzhofer_orders Status auf completed/error setzen",
      "next": [
        "log-metrics"
      ],
      "inputs": [
        "order_id",
        "processing_result"
      ],
      "outputs": [
        "status_updated"
      ],
      "edgeFunction": "welzhofer-order-status"
    },
    {
      "id": "log-metrics",
      "lane": "data",
      "module": "welzhofer/metrics",
      "label": "Metriken loggen",
      "description": "workflow_runs Eintrag: items_processed, duration_ms, category, errors",
      "next": [],
      "inputs": [
        "processing_result",
        "timing"
      ],
      "outputs": [
        "metrics_logged"
      ]
    }
  ],
