  "schedule": {
    "cron": "0 7 * * 1-5",
    "human": "Montag-Freitag 07:00-18:00 (Dauerbetrieb mit 5-Min Polling)",
    "timezone": "Europe/Berlin",
    "pollingIntervalSec": 300
  },
  "guardrails": {
    "constraints": {
      "allowedDays": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday"
      ],
      "allowedHours": {
        "start": "07:00",
        "end": "18:00"
      },
      "maxConcurrentRuns": 1,
      "timeoutMinutes": 660,
      "hardRules": [
        "Auto-Korrektur DEAKTIVIERT seit 20.02.2026 (fuehrte zu falschen Bestellungen)",
        "OCR via GPT-5.2 — keine lokale OCR",
        "XLSX-Export via OneDrive Upload",
        "Stammdaten-Refresh taeglich um 06:00"
      ]
    },
    "variables": [
      {
        "name": "POLLING_INTERVAL",
        "type": "number",
        "default": 300,
        "description": "Email-Polling Intervall in Sekunden"
      },
      {
        "name": "OPENAI_API_KEY",
        "type": "string",
        "default": "from_env",
        "locked": true,
        "description": "GPT-5.2 OCR API Key"
      },
      {
        "name": "CONVERTAPI_KEY",
        "type": "string",
        "default": "from_env",
        "locked": true,
        "description": "ConvertAPI fuer PDF/JPG Konvertierung"
      },
      {
        "name": "EMAIL_ACCOUNT",
        "type": "string",
        "default": "automation@welzhofer.eu",
        "description": "Email-Konto fuer Bestelleingang"
      },
      {
        "name": "REPORT_RECIPIENTS",
        "type": "string[]",
        "default": [
          "amic@welzhofer.eu"
        ],
        "description": "Empfaenger fuer verarbeitete Bestellungen"
      }
    ]
  },
  "lanes": [
    {
      "id": "scheduler",
