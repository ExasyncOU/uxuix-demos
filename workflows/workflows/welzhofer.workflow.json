  "healthCheck": {
    "sql": "SELECT workflow_id, status, started_at, metrics FROM workflow_runs WHERE workflow_id IN ('welzhofer/order-intake','welzhofer/order-status-update','uxuix/welzhofer-start','uxuix/welzhofer-stop') ORDER BY started_at DESC LIMIT 10;",
